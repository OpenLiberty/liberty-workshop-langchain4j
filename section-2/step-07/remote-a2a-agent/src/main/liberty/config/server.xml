<?xml version="1.0" encoding="UTF-8"?>
<server description="Liberty Workshop A2A Pricing Agent Server">

    <!-- Enable features -->
    <featureManager>
    	<platform>jakartaee-10.0</platform>
        <platform>microprofile-7.1</platform>
        <feature>cdi</feature>
        <feature>jsonb</feature>
        <feature>jsonp</feature>
        <feature>restfulWS</feature>
        <feature>servlet</feature>
        <feature>mpConfig</feature>
    </featureManager>

    <!-- HTTP endpoint configuration -->
    <httpEndpoint
        id="defaultHttpEndpoint"
        httpPort="8888"
        host="*"
    />

    <!-- Application configuration -->
    <webApplication
        id="langchain4j-workshop"
        location="langchain4j-workshop.war"
        contextRoot="/">
    </webApplication>

    <!-- Logging configuration -->
    <logging
        traceSpecification="*=info:dev.langchain4j.*=all:com.carmanagement.*=all:org.a2aproject.*=all"
        maxFileSize="20"
        maxFiles="10"
        consoleLogLevel="INFO"
    />
</server>

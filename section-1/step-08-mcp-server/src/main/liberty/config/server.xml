<?xml version="1.0" encoding="UTF-8"?>
<server description="MCP Weather Service">

    <!-- Enable features -->
    <featureManager>
        <platform>jakartaee-10.0</platform>
        <platform>microprofile-7.1</platform>
        <feature>cdi</feature>
        <feature>jsonb</feature>
        <feature>restfulWS</feature>
        <feature>servlet</feature>
        <feature>mpRestClient</feature>
    </featureManager>

    <!-- HTTP endpoint configuration -->
    <httpEndpoint
        id="defaultHttpEndpoint"
        httpPort="9081"
        httpsPort="9444"
        host="*"
    />

    <!-- Application configuration -->
    <applicationManager autoExpand="true"/>
    <webApplication
        id="mcp-weather-service"
        location="mcp-weather-service.war"
        contextRoot="/">
    </webApplication>

    <!-- Logging configuration -->
    <logging
        traceSpecification="*=info:dev.langchain4j.*=all"
        maxFileSize="20"
        maxFiles="10"
        consoleLogLevel="INFO"
    />

    <sslDefault sslRef="defaultSSLConfig" />

    <ssl id="defaultSSLConfig" trustStoreRef="javaTrustStore"/>

    <keyStore
        id="defaultKeyStore" 
        location="key.p12" 
        type="PKCS12" 
        password="password"
    />

    <keyStore
        id="javaTrustStore"
        location="${java.home}/lib/security/cacerts"
        password="changeit"
    />
</server>

<?xml version="1.0" encoding="UTF-8"?>
<server description="Liberty LangChain4J Workshop Server">

    <!-- Enable features -->
    <featureManager>
        <platform>jakartaee-10.0</platform>
        <platform>microprofile-7.1</platform>
        <feature>cdi</feature>
        <feature>websocket</feature>
        <feature>restfulWS</feature>
        <feature>mpConfig</feature>
    </featureManager>

    <!-- HTTP endpoint configuration -->
    <httpEndpoint
        id="defaultHttpEndpoint"
        httpPort="9080"
        httpsPort="9443"
        host="*"
    />

    <!-- Application configuration -->
    <applicationManager autoExpand="true"/>
    <webApplication
        id="langchain4j-workshop"
        location="langchain4j-workshop.war"
        contextRoot="/">
    </webApplication>

    <!-- Logging configuration -->
    <logging
        traceSpecification="*=info:dev.langchain4j.*=all"
        maxFileSize="20"
        maxFiles="10"
        consoleLogLevel="INFO"
    />
</server>
